<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Isidorito - Sistema de Gestión</title>
    <link rel="stylesheet" href="/styles/app-unified.css">
    <style>
        .index-page {
            min-height: 100vh;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 2rem 1rem;
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        }
        
        .index-container {
            max-width: 1000px;
            width: 100%;
        }
        
        .index-header {
            text-align: center;
            margin-bottom: 3rem;
        }
        
        .index-logo {
            font-size: 4rem;
            margin-bottom: 1rem;
        }
        
        .index-title {
            font-size: 2.5rem;
            font-weight: 700;
            color: white;
            margin: 0 0 0.5rem 0;
            text-shadow: 0 2px 4px rgba(0,0,0,0.2);
        }
        
        .index-subtitle {
            font-size: 1.1rem;
            color: rgba(255, 255, 255, 0.9);
        }
        
        .access-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 2rem;
        }
        
        .access-card {
            background: white;
            border-radius: 16px;
            padding: 2.5rem;
            text-align: center;
            text-decoration: none;
            transition: all 0.3s ease;
            box-shadow: 0 10px 30px rgba(0,0,0,0.2);
            position: relative;
            overflow: hidden;
        }
        
        .access-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 5px;
            background: linear-gradient(90deg, #667eea 0%, #764ba2 100%);
        }
        
        .access-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 20px 40px rgba(0,0,0,0.3);
        }
        
        .access-icon {
            font-size: 4rem;
            margin-bottom: 1.5rem;
            display: block;
        }
        
        .access-title {
            font-size: 1.5rem;
            font-weight: 700;
            color: #1f2937;
            margin: 0 0 0.75rem 0;
        }
        
        .access-description {
            font-size: 0.95rem;
            color: #6b7280;
            margin: 0 0 1.5rem 0;
        }
        
        .access-button {
            display: inline-block;
            padding: 0.875rem 2rem;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            border-radius: 8px;
            font-weight: 600;
            text-decoration: none;
            transition: all 0.3s;
        }
        
        .access-button:hover {
            transform: scale(1.05);
            box-shadow: 0 5px 15px rgba(102, 126, 234, 0.4);
            color: white;
        }
        
        .index-footer {
            text-align: center;
            margin-top: 3rem;
            color: rgba(255, 255, 255, 0.8);
            font-size: 0.9rem;
        }
        
        @media (max-width: 768px) {
            .index-logo {
                font-size: 3rem;
            }
            
            .index-title {
                font-size: 2rem;
            }
            
            .access-grid {
                grid-template-columns: 1fr;
                gap: 1.5rem;
            }
            
            .access-card {
                padding: 2rem;
            }
        }
    </style>
</head>
<body>
    <div class="index-page">
        <div class="index-container">
            <div class="index-header">
                <div class="index-logo">🏪</div>
                <h1 class="index-title">Isidorito</h1>
                <p class="index-subtitle">Sistema Integral de Gestión Comercial</p>
            </div>
            
            <div class="access-grid">
                <div class="access-card">
                    <span class="access-icon">👨‍💼</span>
                    <h2 class="access-title">Administrador</h2>
                    <p class="access-description">Gestión completa del sistema, productos, usuarios y reportes</p>
                    <a href="/ingreso-administrador" class="access-button">Ingresar →</a>
                </div>
                
                <div class="access-card">
                    <span class="access-icon">🚚</span>
                    <h2 class="access-title">Repartidores</h2>
                    <p class="access-description">Gestión de pedidos, entregas y rutas de distribución</p>
                    <a href="/ingreso-repartidor" class="access-button">Ingresar →</a>
                </div>
                
                <div class="access-card">
                    <span class="access-icon">💰</span>
                    <h2 class="access-title">Caja</h2>
                    <p class="access-description">Punto de venta, cobros y gestión de ventas directas</p>
                    <a href="/ingreso-caja" class="access-button">Ingresar →</a>
                </div>
            </div>
            
            <div class="index-footer">
                <p>🔒 Sistema Seguro | v1.0 | © 2024 Isidorito</p>
            </div>
        </div>
    </div>
</body>
</html>
