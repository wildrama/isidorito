<%- include('./partials/headerCaja.ejs'); %>
<%- include('./partials/flash.ejs'); %>

<div class="login-container">
    <div class="login-card">
        <div class="login-header">
            <div class="login-icon">💳</div>
            <h1 class="login-title">Acceso a Caja</h1>
            <p class="login-subtitle">Estación: <strong><%= nombreEstacion %></strong></p>
        </div>

        <form action="/ingreso-caja/<%= estacionDeCobroId %>/login" method="POST" class="login-form">
            <div class="form-group-modern">
                <label for="username" class="form-label-modern">Usuario</label>
                <input type="text" 
                       id="username" 
                       name="username" 
                       class="form-control-modern" 
                       placeholder="Ingresa tu usuario"
                       required>
            </div>

            <div class="form-group-modern">
                <label for="password" class="form-label-modern">Contraseña</label>
                <div class="password-wrapper">
                    <input type="password" 
                           id="password" 
                           name="password" 
                           class="form-control-modern" 
                           placeholder="Ingresa tu contraseña"
                           required>
                    <button type="button" class="password-toggle" onclick="togglePasswordCaja()">
                        <span id="eye-icon-caja">👁️</span>
                    </button>
                </div>
            </div>

            <div class="form-check-modern">
                <input type="checkbox" id="remember" class="checkbox-modern">
                <label for="remember" class="checkbox-label">Recordar sesión</label>
            </div>

            <button type="submit" class="btn-login-modern">
                <span>Ingresar a Caja</span>
                <span class="btn-arrow">→</span>
            </button>
        </form>

        <div class="login-footer">
            <p class="security-text">🔒 Conexión segura y encriptada</p>
        </div>
    </div>
</div>

<script>
function togglePasswordCaja() {
    const passwordField = document.getElementById('password');
    const eyeIcon = document.getElementById('eye-icon-caja');
    
    if (passwordField.type === 'password') {
        passwordField.type = 'text';
        eyeIcon.textContent = '🙈';
    } else {
        passwordField.type = 'password';
        eyeIcon.textContent = '👁️';
    }
}
</script>

<%- include('./partials/footer.ejs'); %>
