<%- include('./partials/headerAdm.ejs'); %>

<%- include('./partials/flash.ejs'); %>

<div class="admin-dashboard">
    <div class="form-container">
        <!-- Breadcrumb -->
        <nav class="breadcrumb-nav">
            <a href="/administrador" class="breadcrumb-link">Dashboard</a>
            <span class="breadcrumb-separator">/</span>
            <a href="/administrador/productos" class="breadcrumb-link">Productos</a>
            <span class="breadcrumb-separator">/</span>
            <span class="breadcrumb-current">Nuevo Producto</span>
        </nav>

        <!-- Form Header -->
        <div class="form-header">
            <h1 class="form-title">➕ Nuevo Producto</h1>
            <p class="form-subtitle">Completa todos los campos para agregar un producto al inventario</p>
        </div>

        <!-- Form -->
        <form action="/administrador/productos/nuevo" 
              method="POST" 
              enctype="multipart/form-data" 
              class="modern-form">
            
            <div class="form-grid">
                <!-- Información Básica -->
                <div class="form-section">
                    <h3 class="section-title-form">📝 Información Básica</h3>
                    
                    <div class="form-group-modern">
                        <label for="nombre" class="form-label-modern">
                            Nombre del Producto <span class="required">*</span>
                        </label>
                        <input type="text" 
                               id="nombre" 
                               name="nombre" 
                               class="form-control-modern" 
                               placeholder="Ej: Laptop HP Pavilion 15"
                               required>
                        <small class="form-help">Nombre descriptivo y claro del producto</small>
                    </div>

                    <div class="form-row">
                        <div class="form-group-modern">
                            <label for="categoria" class="form-label-modern">
                                Categoría <span class="required">*</span>
                            </label>
                            <select id="categoria" name="categoria" class="form-control-modern" required>
                                <option value="">Selecciona una categoría</option>
                                <option value="Electrónica">Electrónica</option>
                                <option value="Ropa">Ropa</option>
                                <option value="Alimentos">Alimentos</option>
                                <option value="Hogar">Hogar</option>
                                <option value="Deportes">Deportes</option>
                                <option value="Libros">Libros</option>
                                <option value="Juguetes">Juguetes</option>
                                <option value="Otros">Otros</option>
                            </select>
                        </div>

                        <div class="form-group-modern">
                            <label for="codigo" class="form-label-modern">Código/SKU</label>
                            <input type="text" 
                                   id="codigo" 
                                   name="codigo" 
                                   class="form-control-modern" 
                                   placeholder="Ej: PROD-001">
                            <small class="form-help">Código único del producto</small>
                        </div>
                    </div>

                    <div class="form-group-modern">
                        <label for="descripcion" class="form-label-modern">Descripción</label>
                        <textarea id="descripcion" 
                                  name="descripcion" 
                                  class="form-control-modern" 
                                  rows="3"
                                  placeholder="Describe las características principales del producto"></textarea>
                    </div>
                </div>

                <!-- Precio e Inventario -->
                <div class="form-section">
                    <h3 class="section-title-form">💰 Precio e Inventario</h3>
                    
                    <div class="form-row">
                        <div class="form-group-modern">
                            <label for="precio" class="form-label-modern">
                                Precio <span class="required">*</span>
                            </label>
                            <div class="input-with-icon">
                                <span class="input-icon">$</span>
                                <input type="number" 
                                       id="precio" 
                                       name="precio" 
                                       class="form-control-modern with-icon" 
                                       placeholder="0.00"
                                       step="0.01"
                                       min="0"
                                       required>
                            </div>
                            <small class="form-help">Precio de venta al público</small>
                        </div>

                        <div class="form-group-modern">
                            <label for="stock" class="form-label-modern">
                                Stock Inicial <span class="required">*</span>
                            </label>
                            <div class="input-with-icon">
                                <span class="input-icon">📦</span>
                                <input type="number" 
                                       id="stock" 
                                       name="stock" 
                                       class="form-control-modern with-icon" 
                                       placeholder="0"
                                       min="0"
                                       value="0"
                                       required>
                            </div>
                            <small class="form-help">Cantidad disponible en inventario</small>
                        </div>
                    </div>

                    <div class="alert-info">
                        <span class="alert-icon">💡</span>
                        <span>Los productos con stock menor a 10 unidades se marcarán como "Stock Bajo"</span>
                    </div>
                </div>

                <!-- Imagen -->
                <div class="form-section">
                    <h3 class="section-title-form">🖼️ Imagen del Producto</h3>
                    
                    <div class="form-group-modern">
                        <label for="imagen" class="form-label-modern">Subir Imagen</label>
                        <div class="file-upload-wrapper">
                            <input type="file" 
                                   id="imagen" 
                                   name="imagen" 
                                   class="file-input" 
                                   accept="image/*"
                                   onchange="previewImage(event)">
                            <label for="imagen" class="file-label">
                                <span class="file-icon">📁</span>
                                <span class="file-text">Seleccionar archivo</span>
                            </label>
                        </div>
                        <small class="form-help">Formatos: JPG, PNG, GIF (Máx. 5MB)</small>
                        
                        <div id="imagePreview" class="image-preview"></div>
                    </div>
                </div>
            </div>

            <!-- Form Actions -->
            <div class="form-actions">
                <a href="/administrador/productos" class="btn-secondary-modern">
                    Cancelar
                </a>
                <button type="submit" class="btn-primary-modern">
                    <span class="btn-icon">💾</span>
                    Guardar Producto
                </button>
            </div>
        </form>
    </div>
</div>

<script>
function previewImage(event) {
    const preview = document.getElementById('imagePreview');
    const file = event.target.files[0];
    const fileText = document.querySelector('.file-text');
    
    if (file) {
        // Validar tamaño
        if (file.size > 5 * 1024 * 1024) {
            alert('El archivo es muy grande. Máximo 5MB');
            event.target.value = '';
            return;
        }
        
        fileText.textContent = file.name;
        const reader = new FileReader();
        
        reader.onload = function(e) {
            preview.innerHTML = `
                <div class="preview-container">
                    <img src="${e.target.result}" alt="Preview" class="preview-img">
                    <button type="button" class="preview-remove" onclick="removeImage()">✕</button>
                </div>
            `;
        }
        
        reader.readAsDataURL(file);
    }
}

function removeImage() {
    document.getElementById('imagen').value = '';
    document.getElementById('imagePreview').innerHTML = '';
    document.querySelector('.file-text').textContent = 'Seleccionar archivo';
}
</script>

<%- include('./partials/footer.ejs'); %>
