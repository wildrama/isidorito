<%- include('../partials/headerAdm.ejs'); %>

<div class="admin-dashboard">
    <div class="form-container">
        <!-- Breadcrumb -->
        <nav class="breadcrumb-nav">
            <a href="/administrador" class="breadcrumb-link">Dashboard</a>
            <span class="breadcrumb-separator">/</span>
            <a href="/administrador/ofertas" class="breadcrumb-link">Ofertas</a>
            <span class="breadcrumb-separator">/</span>
            <span class="breadcrumb-current">Agregar Oferta Individual</span>
        </nav>

        <!-- Page Header -->
        <div class="form-header">
            <h1 class="form-title">🏷️ Crear Oferta Individual</h1>
            <p class="form-subtitle">Selecciona un producto y establece un precio especial</p>
        </div>

        <!-- Main Form -->
        <form id="ofertaForm" class="oferta-form">
            <!-- Product Search Section -->
            <div class="card mb-4">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">Paso 1: Seleccionar Producto</h5>
                </div>
                <div class="card-body">
                    <!-- Product Search Input Component -->
                    <%- include('../partials/productSearchInput', {
                        inputId: 'ofertaProductSearch',
                        resultsId: 'ofertaResults',
                        selectedProductId: 'selectedProductId'
                    }) %>
                </div>
            </div>

            <!-- Pricing Section -->
            <div class="card mb-4">
                <div class="card-header bg-info text-white">
                    <h5 class="mb-0">Paso 2: Establecer Precios</h5>
                </div>
                <div class="card-body">
                    <!-- Price Comparison -->
                    <div class="row mb-4">
                        <div class="col-md-4">
                            <div class="price-box">
                                <label class="price-label">Precio Regular</label>
                                <div class="price-value" id="precioRegular">
                                    <span class="badge bg-secondary">Selecciona producto</span>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="price-box text-center">
                                <div style="font-size: 2rem; color: #dc3545; margin-top: 2rem;">→</div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="price-box border-success">
                                <label class="price-label">Precio Oferta</label>
                                <div class="price-value" id="precioOfertaDisplay">
                                    <span class="badge bg-success">Ingresa precio</span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Discount Display -->
                    <div id="discountInfo" class="alert alert-success" style="display: none;">
                        <strong>Ahorro para el cliente:</strong>
                        <div id="discountText"></div>
                    </div>

                    <!-- Price Input -->
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="precioOferta" class="form-label">Precio Oferta *</label>
                                <div class="input-group input-group-lg">
                                    <span class="input-group-text">$</span>
                                    <input type="number" 
                                           id="precioOferta" 
                                           name="precioOferta" 
                                           class="form-control"
                                           placeholder="0.00"
                                           step="0.01"
                                           min="0"
                                           required>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="cantidadDisponible" class="form-label">Cantidad Disponible</label>
                                <input type="number" 
                                       id="cantidadDisponible" 
                                       class="form-control"
                                       readonly>
                                <small class="text-muted">Se carga automáticamente</small>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Duration Section -->
            <div class="card mb-4">
                <div class="card-header bg-warning text-dark">
                    <h5 class="mb-0">Paso 3: Duración de la Oferta</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="fechaInicio" class="form-label">Fecha Inicio</label>
                                <input type="date" 
                                       id="fechaInicio" 
                                       name="fechaInicio"
                                       class="form-control"
                                       required>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="fechaFin" class="form-label">Fecha Fin</label>
                                <input type="date" 
                                       id="fechaFin" 
                                       name="fechaFin"
                                       class="form-control"
                                       required>
                            </div>
                        </div>
                    </div>

                    <div class="form-group">
                        <label for="descripcion" class="form-label">Descripción (Opcional)</label>
                        <textarea id="descripcion" 
                                  name="descripcion" 
                                  class="form-control"
                                  rows="3"
                                  placeholder="ej: Oferta por inauguración, liquidación, etc."></textarea>
                    </div>
                </div>
            </div>

            <!-- Summary Section -->
            <div class="card mb-4" id="summaryCard" style="display: none;">
                <div class="card-header bg-light">
                    <h5 class="mb-0">Resumen de la Oferta</h5>
                </div>
                <div class="card-body">
                    <div class="summary-item">
                        <strong>Producto:</strong>
                        <span id="summaryProducto"></span>
                    </div>
                    <div class="summary-item">
                        <strong>Precio Original:</strong>
                        <span id="summaryPrecioOriginal"></span>
                    </div>
                    <div class="summary-item text-success">
                        <strong>Precio Oferta:</strong>
                        <span id="summaryPrecioOferta"></span>
                    </div>
                    <div class="summary-item">
                        <strong>Descuento:</strong>
                        <span id="summaryDescuento"></span>
                    </div>
                    <div class="summary-item">
                        <strong>Vigencia:</strong>
                        <span id="summaryVigencia"></span>
                    </div>
                </div>
            </div>

            <!-- Action Buttons -->
            <div class="form-actions">
                <button type="submit" class="btn btn-success btn-lg" id="submitBtn" disabled>
                    ✓ Crear Oferta
                </button>
                <a href="/administrador/ofertas" class="btn btn-secondary btn-lg">
                    ← Cancelar
                </a>
            </div>

            <!-- Hidden inputs -->
            <input type="hidden" id="selectedProductId" name="productId">
        </form>
    </div>
</div>

<!-- Styles -->
<style>
.admin-dashboard {
    padding: 2rem;
    background-color: #f5f5f5;
    min-height: 100vh;
}

.price-box {
    padding: 1.5rem;
    background-color: #f8f9fa;
    border-radius: 0.375rem;
    border-left: 4px solid #0d6efd;
    text-align: center;
}

.price-box.border-success {
    border-left-color: #198754;
    background-color: #f0fdf4;
}

.price-label {
    font-size: 0.875rem;
    color: #666;
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

.price-value {
    font-size: 1.75rem;
    font-weight: 700;
    margin-top: 1rem;
}

.form-actions {
    display: flex;
    gap: 1rem;
    margin-top: 2rem;
}

.form-actions button,
.form-actions a {
    flex: 1;
}

.card {
    box-shadow: 0 0.125rem 0.25rem rgba(0, 0, 0, 0.075);
    border: none;
    margin-bottom: 1.5rem;
}

.card-header {
    border-bottom: 1px solid rgba(0, 0, 0, 0.125);
    padding: 1rem 1.25rem;
}

.card-body {
    padding: 1.5rem;
}

.summary-item {
    padding: 0.75rem 0;
    border-bottom: 1px solid #e9ecef;
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.summary-item:last-child {
    border-bottom: none;
}

.input-group-lg .form-control,
.input-group-lg .input-group-text {
    padding: 0.75rem 1rem;
    font-size: 1.1rem;
}
</style>

<!-- JavaScript -->
<script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
<script src="/js/productSearch.js"></script>

<script>
(function() {
    const form = document.getElementById('ofertaForm');
    const selectedProductInput = document.getElementById('selectedProductId');
    const precioOfertaInput = document.getElementById('precioOferta');
    const fechaInicioInput = document.getElementById('fechaInicio');
    const fechaFinInput = document.getElementById('fechaFin');
    const submitBtn = document.getElementById('submitBtn');
    const precioRegularDiv = document.getElementById('precioRegular');
    const cantidadDisponibleInput = document.getElementById('cantidadDisponible');
    const discountInfo = document.getElementById('discountInfo');
    const summaryCard = document.getElementById('summaryCard');

    let selectedProduct = null;

    // Set today's date as default start date
    const today = new Date().toISOString().split('T')[0];
    fechaInicioInput.value = today;

    // Escuchar selección de producto
    document.addEventListener('productSelected', function(e) {
        if (e.detail.selectedProductId === 'selectedProductId') {
            selectedProduct = e.detail.producto;
            
            precioRegularDiv.innerHTML = `
                <strong class="fs-4">$${(selectedProduct.precioMinorista || 0).toFixed(2)}</strong>
            `;
            
            cantidadDisponibleInput.value = selectedProduct.cantidad || 0;
            
            precioOfertaInput.value = '';
            precioOfertaInput.focus();
            
            submitBtn.disabled = false;
            updateSummary();
        }
    });

    // Calcular descuento cuando cambia el precio
    precioOfertaInput.addEventListener('input', updateSummary);
    fechaInicioInput.addEventListener('change', updateSummary);
    fechaFinInput.addEventListener('change', updateSummary);

    function updateSummary() {
        if (!selectedProduct) return;

        const precioOriginal = selectedProduct.precioMinorista || 0;
        const precioOferta = parseFloat(precioOfertaInput.value) || 0;

        if (precioOferta === 0) {
            discountInfo.style.display = 'none';
            summaryCard.style.display = 'none';
            return;
        }

        // Calcular descuento
        const descuento = precioOriginal - precioOferta;
        const porcentaje = ((descuento / precioOriginal) * 100).toFixed(1);

        // Mostrar info de descuento
        if (descuento > 0) {
            document.getElementById('precioOfertaDisplay').innerHTML = `
                <strong class="text-success fs-4">$${precioOferta.toFixed(2)}</strong>
            `;
            
            discountInfo.innerHTML = `
                <strong>Ahorro para el cliente:</strong>
                <div><strong>$${descuento.toFixed(2)}</strong> (${porcentaje}% de descuento)</div>
            `;
            discountInfo.style.display = 'block';
        } else if (descuento < 0) {
            discountInfo.innerHTML = `
                <div class="alert alert-warning mb-0">
                    ⚠️ El precio de oferta es mayor que el precio regular
                </div>
            `;
            discountInfo.className = 'alert alert-warning';
            discountInfo.style.display = 'block';
        } else {
            discountInfo.style.display = 'none';
        }

        // Mostrar resumen
        if (selectedProduct && precioOferta > 0) {
            document.getElementById('summaryProducto').textContent = selectedProduct.nombre;
            document.getElementById('summaryPrecioOriginal').textContent = `$${precioOriginal.toFixed(2)}`;
            document.getElementById('summaryPrecioOferta').textContent = `$${precioOferta.toFixed(2)}`;
            document.getElementById('summaryDescuento').textContent = `${porcentaje}% ($${descuento.toFixed(2)})`;
            
            const fechaInicio = fechaInicioInput.value || 'N/A';
            const fechaFin = fechaFinInput.value || 'N/A';
            document.getElementById('summaryVigencia').textContent = `${fechaInicio} a ${fechaFin}`;
            
            summaryCard.style.display = 'block';
        }
    }

    // Enviar formulario
    form.addEventListener('submit', async function(e) {
        e.preventDefault();

        if (!selectedProduct) {
            alert('Por favor selecciona un producto');
            return;
        }

        if (!precioOfertaInput.value) {
            alert('Por favor ingresa un precio de oferta');
            return;
        }

        if (!fechaInicioInput.value || !fechaFinInput.value) {
            alert('Por favor selecciona las fechas de inicio y fin');
            return;
        }

        try {
            submitBtn.disabled = true;
            submitBtn.innerHTML = '⏳ Guardando...';

            const response = await axios.post('/administrador/ofertas/create', {
                productId: selectedProduct._id,
                precioOferta: parseFloat(precioOfertaInput.value),
                fechaInicio: fechaInicioInput.value,
                fechaFin: fechaFinInput.value,
                descripcion: document.getElementById('descripcion').value || ''
            });

            if (response.data.success) {
                alert('✓ Oferta creada correctamente');
                setTimeout(() => {
                    window.location.href = '/administrador/ofertas';
                }, 1000);
            } else {
                alert('Error: ' + response.data.message);
                submitBtn.disabled = false;
                submitBtn.innerHTML = '✓ Crear Oferta';
            }
        } catch (error) {
            console.error('Error:', error);
            alert('Error al crear oferta: ' + (error.response?.data?.message || error.message));
            submitBtn.disabled = false;
            submitBtn.innerHTML = '✓ Crear Oferta';
        }
    });
})();
</script>
