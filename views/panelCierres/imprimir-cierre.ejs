<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Resumen de Cierre - <%= cierre.ubicacionDeEstacion %></title>
    <style>
        @page { size: A4 portrait; margin: 12mm; }
        body {
            font-family: Arial, Helvetica, sans-serif;
            color: #1f2937;
            margin: 0;
            padding: 0;
            background: #fff;
        }
        .sheet {
            max-width: 820px;
            margin: 0 auto;
        }
        .header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            gap: 1rem;
            border-bottom: 2px solid #1f2937;
            padding-bottom: 12px;
            margin-bottom: 16px;
        }
        .header h1 {
            margin: 0 0 4px;
            font-size: 24px;
        }
        .header p {
            margin: 2px 0;
            font-size: 13px;
        }
        .badge {
            display: inline-block;
            padding: 4px 10px;
            border-radius: 999px;
            background: #e0f2fe;
            color: #0c4a6e;
            font-weight: 700;
            font-size: 12px;
            text-transform: uppercase;
        }
        .grid {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 12px;
            margin-bottom: 18px;
        }
        .card {
            border: 1px solid #d1d5db;
            border-radius: 12px;
            padding: 12px;
            background: #f9fafb;
        }
        .card h3 {
            margin: 0 0 8px;
            font-size: 15px;
        }
        .value {
            font-size: 20px;
            font-weight: 700;
            margin: 0;
        }
        .muted { color: #6b7280; }
        .section { margin-bottom: 18px; }
        .section h2 {
            margin: 0 0 10px;
            font-size: 17px;
            border-bottom: 1px solid #d1d5db;
            padding-bottom: 6px;
        }
        table {
            width: 100%;
            border-collapse: collapse;
            font-size: 13px;
        }
        th, td {
            border: 1px solid #d1d5db;
            padding: 8px;
            text-align: left;
            vertical-align: top;
        }
        th {
            background: #f3f4f6;
        }
        .right { text-align: right; }
        .footer {
            margin-top: 18px;
            font-size: 12px;
            color: #6b7280;
            text-align: center;
        }
        @media print {
            .no-print { display: none; }
        }
    </style>
</head>
<body>
    <div class="sheet">
        <div class="header">
            <div>
                <h1>Resumen de Cierre de Caja</h1>
                <p><strong>Estación:</strong> <%= cierre.ubicacionDeEstacion %></p>
                <p><strong>Usuario:</strong> <%= cierre.nombreDelUsuario %></p>
                <p><strong>Desde:</strong> <%= new Date(cierre.fechaDeApertura).toLocaleString('es-AR') %></p>
                <p><strong>Hasta:</strong> <%= new Date(cierre.fechaDeCierre).toLocaleString('es-AR') %></p>
            </div>
            <div>
                <span class="badge"><%= isPreview ? 'Vista previa' : cierre.periodo %></span>
            </div>
        </div>

        <div class="grid">
            <div class="card">
                <h3>Dinero inicial</h3>
                <p class="value">$<%= Number(cierre.dineroDeInicio || 0).toFixed(2) %></p>
            </div>
            <div class="card">
                <h3>Dinero esperado</h3>
                <p class="value">$<%= Number(cierre.dineroEsperado || 0).toFixed(2) %></p>
            </div>
            <div class="card">
                <h3>Dinero contado</h3>
                <p class="value">$<%= Number(cierre.dineroReal || cierre.dineroEnCaja || 0).toFixed(2) %></p>
            </div>
            <div class="card">
                <h3>Diferencia</h3>
                <p class="value">$<%= Number(cierre.diferencia || 0).toFixed(2) %></p>
            </div>
        </div>

        <div class="section">
            <h2>Ventas del período</h2>
            <table>
                <thead>
                    <tr>
                        <th>Medio</th>
                        <th>Cantidad</th>
                        <th class="right">Monto</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>Efectivo</td>
                        <td><%= cierre.ventasEnEfectivo?.cantidad || 0 %></td>
                        <td class="right">$<%= Number(cierre.ventasEnEfectivo?.montoTotal || 0).toFixed(2) %></td>
                    </tr>
                    <tr>
                        <td>Tarjeta / Transferencia</td>
                        <td><%= cierre.ventasEnOtro?.cantidad || 0 %></td>
                        <td class="right">$<%= Number(cierre.ventasEnOtro?.montoTotal || 0).toFixed(2) %></td>
                    </tr>
                </tbody>
            </table>
        </div>

        <div class="section">
            <h2>Ingresos y egresos manuales</h2>
            <table>
                <thead>
                    <tr>
                        <th>Concepto</th>
                        <th>Cantidad</th>
                        <th class="right">Monto</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>Ingresos manuales</td>
                        <td><%= cierre.ingresosManualDinero?.cantidad || 0 %></td>
                        <td class="right">$<%= Number(cierre.ingresosManualDinero?.montoTotal || 0).toFixed(2) %></td>
                    </tr>
                    <tr>
                        <td>Egresos manuales</td>
                        <td><%= cierre.egresosManualDinero?.cantidad || 0 %></td>
                        <td class="right">$<%= Number(cierre.egresosManualDinero?.montoTotal || 0).toFixed(2) %></td>
                    </tr>
                </tbody>
            </table>
        </div>

        <% if (cierre.detallesDeVentas && cierre.detallesDeVentas.length) { %>
            <div class="section">
                <h2>Operaciones incluidas</h2>
                <table>
                    <thead>
                        <tr>
                            <th>Fecha</th>
                            <th>Tipo de pago</th>
                            <th class="right">Monto</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% cierre.detallesDeVentas.forEach((detalle) => { %>
                            <tr>
                                <td><%= new Date(detalle.fecha).toLocaleString('es-AR') %></td>
                                <td><%= detalle.tipoPago %></td>
                                <td class="right">$<%= Number(detalle.monto || 0).toFixed(2) %></td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        <% } %>

        <% if (cierre.notasDelCierre) { %>
            <div class="section">
                <h2>Notas del cierre</h2>
                <div class="card">
                    <p><%= cierre.notasDelCierre %></p>
                </div>
            </div>
        <% } %>

        <div class="footer">
            <p>Resumen generado desde Isidorito · Cierre administrativo de caja</p>
        </div>
    </div>

    <script>
        window.onload = function () {
            setTimeout(function () { window.print(); }, 180);
        };
        window.onafterprint = function () {
            setTimeout(function () { window.close(); }, 250);
        };
    </script>
</body>
</html>