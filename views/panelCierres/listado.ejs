<%- include('../partials/navbar') %>
<%- include('../partials/flash') %>

<div class="container-fluid mt-4">
    <!-- Header -->
    <div class="cierres-header">
        <div class="cierres-title-section">
            <h1 class="cierres-main-title">
                <i class="fas fa-cash-register"></i>
                Historial de Cierres de Caja
            </h1>
            <p class="cierres-subtitle">Gestiona y visualiza todos los cierres realizados</p>
        </div>
    </div>

    <!-- Resumen de Totales -->
    <div class="cierres-totales-grid">
        <div class="cierre-total-card">
            <div class="total-card-icon" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
                <i class="fas fa-calendar-week"></i>
            </div>
            <div class="total-card-content">
                <p class="total-card-label">Esta Semana</p>
                <p class="total-card-value" id="totalSemanal">$0.00</p>
            </div>
        </div>

        <div class="cierre-total-card">
            <div class="total-card-icon" style="background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);">
                <i class="fas fa-calendar-alt"></i>
            </div>
            <div class="total-card-content">
                <p class="total-card-label">Este Mes</p>
                <p class="total-card-value" id="totalMensual">$0.00</p>
            </div>
        </div>

        <div class="cierre-total-card">
            <div class="total-card-icon" style="background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);">
                <i class="fas fa-globe"></i>
            </div>
            <div class="total-card-content">
                <p class="total-card-label">Total Global</p>
                <p class="total-card-value" id="totalGlobal">$0.00</p>
            </div>
        </div>

        <div class="cierre-total-card">
            <div class="total-card-icon" style="background: linear-gradient(135deg, #43e97b 0%, #38f9d7 100%);">
                <i class="fas fa-chart-line"></i>
            </div>
            <div class="total-card-content">
                <p class="total-card-label">Cantidad Cierres</p>
                <p class="total-card-value" id="cantidadCierres"><%= cierresDeCaja.length %></p>
            </div>
        </div>
    </div>

    <!-- Tabla de Cierres -->
    <div class="cierres-table-container">
        <div class="cierres-table-header">
            <h2><i class="fas fa-list"></i> Historial Completo</h2>
            <div class="cierres-table-actions">
                <input type="text" id="searchCierres" class="cierres-search-input" placeholder="Buscar por estación, usuario...">
            </div>
        </div>

        <% if (cierresDeCaja.length > 0) { %>
            <!-- Vista Desktop -->
            <div class="cierres-table-wrapper desktop-view">
                <table class="cierres-table">
                    <thead>
                        <tr>
                            <th>Fecha</th>
                            <th>Estación</th>
                            <th>Usuario</th>
                            <th>Dinero Esperado</th>
                            <th>Dinero Real</th>
                            <th>Diferencia</th>
                            <th>Ventas Efectivo</th>
                            <th>Estado</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody id="cierresTableBody">
                        <% cierresDeCaja.forEach(cierre => { %>
                            <tr class="cierre-row" data-cierre="<%= cierre._id %>">
                                <td data-label="Fecha">
                                    <span class="fecha-badge">
                                        <%= new Date(cierre.fechaDeCierre).toLocaleDateString('es-AR', { 
                                            year: 'numeric', month: '2-digit', day: '2-digit' 
                                        }) %>
                                        <small><%= new Date(cierre.fechaDeCierre).toLocaleTimeString('es-AR', { 
                                            hour: '2-digit', minute: '2-digit' 
                                        }) %></small>
                                    </span>
                                </td>
                                <td data-label="Estación">
                                    <span class="estacion-badge">
                                        <i class="fas fa-map-marker-alt"></i>
                                        <%= cierre.ubicacionDeEstacion %>
                                    </span>
                                </td>
                                <td data-label="Usuario">
                                    <span class="usuario-badge">
                                        <%= cierre.nombreDelUsuario %>
                                    </span>
                                </td>
                                <td data-label="Dinero Esperado">
                                    <span class="money-badge expected">
                                        $<%= cierre.dineroEsperado.toFixed(2) %>
                                    </span>
                                </td>
                                <td data-label="Dinero Real">
                                    <span class="money-badge real">
                                        $<%= cierre.dineroReal.toFixed(2) %>
                                    </span>
                                </td>
                                <td data-label="Diferencia">
                                    <span class="diferencia-badge <%= cierre.diferencia > 0 ? 'ganancia' : cierre.diferencia < 0 ? 'perdida' : 'igual' %>">
                                        $<%= cierre.diferencia.toFixed(2) %>
                                    </span>
                                </td>
                                <td data-label="Ventas Efectivo">
                                    <span class="ventas-badge">
                                        <%= cierre.ventasEnEfectivo.cantidad %> ops - $<%= cierre.ventasEnEfectivo.montoTotal.toFixed(2) %>
                                    </span>
                                </td>
                                <td data-label="Estado">
                                    <span class="estado-badge <%= cierre.estado === 'CERRADO' ? 'cerrado' : 'abierto' %>">
                                        <%= cierre.estado %>
                                    </span>
                                </td>
                                <td data-label="Acciones" class="acciones-cell">
                                    <a href="/administrador/cierres-caja/<%= cierre._id %>" class="btn-accion ver-btn" title="Ver detalles">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                </td>
                            </tr>
                        <% }); %>
                    </tbody>
                </table>
            </div>

            <!-- Vista Mobile -->
            <div class="cierres-mobile-view mobile-only" id="cierresMobileView">
                <% cierresDeCaja.forEach(cierre => { %>
                    <div class="cierre-mobile-card">
                        <div class="mobile-card-header">
                            <div class="mobile-card-title">
                                <strong><%= cierre.ubicacionDeEstacion %></strong>
                                <small><%= new Date(cierre.fechaDeCierre).toLocaleDateString('es-AR') %></small>
                            </div>
                            <span class="estado-badge <%= cierre.estado === 'CERRADO' ? 'cerrado' : 'abierto' %>">
                                <%= cierre.estado %>
                            </span>
                        </div>
                        <div class="mobile-card-content">
                            <div class="card-row">
                                <span class="card-label">Usuario:</span>
                                <span class="card-value"><%= cierre.nombreDelUsuario %></span>
                            </div>
                            <div class="card-row">
                                <span class="card-label">Dinero Esperado:</span>
                                <span class="card-value">$<%= cierre.dineroEsperado.toFixed(2) %></span>
                            </div>
                            <div class="card-row">
                                <span class="card-label">Dinero Real:</span>
                                <span class="card-value">$<%= cierre.dineroReal.toFixed(2) %></span>
                            </div>
                            <div class="card-row">
                                <span class="card-label">Diferencia:</span>
                                <span class="card-value diferencia <%= cierre.diferencia > 0 ? 'ganancia' : cierre.diferencia < 0 ? 'perdida' : 'igual' %>">
                                    $<%= cierre.diferencia.toFixed(2) %>
                                </span>
                            </div>
                            <div class="card-row">
                                <span class="card-label">Ventas Efectivo:</span>
                                <span class="card-value"><%= cierre.ventasEnEfectivo.cantidad %> ops - $<%= cierre.ventasEnEfectivo.montoTotal.toFixed(2) %></span>
                            </div>
                        </div>
                        <div class="mobile-card-actions">
                            <a href="/administrador/cierres-caja/<%= cierre._id %>" class="btn-mobile-ver">
                                <i class="fas fa-eye"></i> Ver Detalles
                            </a>
                        </div>
                    </div>
                <% }); %>
            </div>
        <% } else { %>
            <div class="empty-state">
                <i class="fas fa-inbox"></i>
                <p>No hay cierres de caja registrados aún</p>
                <p class="empty-state-hint">Los cierres aparecerán aquí cuando se realicen</p>
            </div>
        <% } %>
    </div>
</div>

<style>
    /* ============================================
       HEADER
       ============================================ */
    .cierres-header {
        margin-bottom: 2rem;
        padding: 1.5rem;
        background: linear-gradient(135deg, var(--primary-color) 0%, #764ba2 100%);
        border-radius: var(--radius-md);
        color: white;
    }

    .cierres-title-section {
        text-align: center;
    }

    .cierres-main-title {
        font-size: 2rem;
        font-weight: 700;
        margin: 0 0 0.5rem 0;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 1rem;
    }

    .cierres-main-title i {
        font-size: 2.2rem;
    }

    .cierres-subtitle {
        margin: 0;
        font-size: 1rem;
        opacity: 0.9;
    }

    /* ============================================
       TOTALES - GRID CARDS
       ============================================ */
    .cierres-totales-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 1.5rem;
        margin-bottom: 2rem;
    }

    .cierre-total-card {
        background: white;
        border-radius: var(--radius-md);
        padding: 1.5rem;
        display: flex;
        align-items: center;
        gap: 1.5rem;
        box-shadow: var(--shadow-sm);
        border: 1px solid var(--border-color);
        transition: all 0.3s ease;
    }

    .cierre-total-card:hover {
        transform: translateY(-4px);
        box-shadow: var(--shadow-lg);
    }

    .total-card-icon {
        width: 60px;
        height: 60px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 1.5rem;
        flex-shrink: 0;
    }

    .total-card-content {
        flex: 1;
    }

    .total-card-label {
        margin: 0;
        font-size: 0.875rem;
        color: var(--text-secondary);
        font-weight: 500;
    }

    .total-card-value {
        margin: 0.25rem 0 0 0;
        font-size: 1.75rem;
        font-weight: 700;
        color: var(--text-primary);
    }

    /* ============================================
       TABLA CONTAINER
       ============================================ */
    .cierres-table-container {
        background: white;
        border-radius: var(--radius-md);
        padding: 1.5rem;
        box-shadow: var(--shadow-sm);
        border: 1px solid var(--border-color);
    }

    .cierres-table-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 1.5rem;
        gap: 1rem;
        flex-wrap: wrap;
    }

    .cierres-table-header h2 {
        margin: 0;
        font-size: 1.25rem;
        color: var(--text-primary);
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .cierres-search-input {
        padding: 0.75rem 1rem;
        border: 1px solid var(--border-color);
        border-radius: 8px;
        font-size: 0.95rem;
        background: var(--background-light);
        width: 250px;
    }

    .cierres-search-input:focus {
        outline: none;
        border-color: var(--primary-color);
        background: white;
        box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.1);
    }

    /* ============================================
       TABLA DESKTOP
       ============================================ */
    .cierres-table-wrapper {
        overflow-x: auto;
    }

    .cierres-table {
        width: 100%;
        border-collapse: collapse;
    }

    .cierres-table thead th {
        background: var(--background-light);
        padding: 1rem;
        text-align: left;
        font-weight: 600;
        color: var(--text-primary);
        border-bottom: 2px solid var(--border-color);
        font-size: 0.9rem;
    }

    .cierres-table tbody tr {
        border-bottom: 1px solid var(--border-color);
        transition: background-color 0.2s ease;
    }

    .cierres-table tbody tr:hover {
        background-color: rgba(99, 102, 241, 0.02);
    }

    .cierres-table tbody td {
        padding: 1rem;
        vertical-align: middle;
        font-size: 0.95rem;
    }

    /* ============================================
       BADGES & STYLES
       ============================================ */
    .fecha-badge {
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
        font-weight: 600;
        color: var(--text-primary);
    }

    .fecha-badge small {
        font-size: 0.8rem;
        color: var(--text-secondary);
        font-weight: normal;
    }

    .estacion-badge,
    .usuario-badge {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.5rem 0.75rem;
        background: var(--background-light);
        border-radius: 6px;
        font-size: 0.9rem;
        color: var(--text-primary);
    }

    .estacion-badge i {
        color: var(--primary-color);
    }

    .money-badge {
        display: inline-block;
        padding: 0.5rem 0.75rem;
        border-radius: 6px;
        font-weight: 600;
        font-size: 0.9rem;
    }

    .money-badge.expected {
        background: rgba(59, 130, 246, 0.1);
        color: #1e40af;
    }

    .money-badge.real {
        background: rgba(34, 197, 94, 0.1);
        color: #15803d;
    }

    .diferencia-badge {
        display: inline-block;
        padding: 0.5rem 0.75rem;
        border-radius: 6px;
        font-weight: 600;
        font-size: 0.9rem;
    }

    .diferencia-badge.ganancia {
        background: rgba(16, 185, 129, 0.1);
        color: #065f46;
    }

    .diferencia-badge.perdida {
        background: rgba(239, 68, 68, 0.1);
        color: #7f1d1d;
    }

    .diferencia-badge.igual {
        background: rgba(107, 114, 128, 0.1);
        color: #374151;
    }

    .ventas-badge {
        display: inline-block;
        padding: 0.5rem 0.75rem;
        background: rgba(139, 92, 246, 0.1);
        color: #5b21b6;
        border-radius: 6px;
        font-size: 0.9rem;
        font-weight: 500;
    }

    .estado-badge {
        display: inline-block;
        padding: 0.5rem 1rem;
        border-radius: 20px;
        font-weight: 600;
        font-size: 0.85rem;
        text-transform: uppercase;
    }

    .estado-badge.cerrado {
        background: rgba(34, 197, 94, 0.15);
        color: #15803d;
    }

    .estado-badge.abierto {
        background: rgba(245, 158, 11, 0.15);
        color: #92400e;
    }

    /* ============================================
       ACCIONES
       ============================================ */
    .acciones-cell {
        text-align: center;
    }

    .btn-accion {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 36px;
        height: 36px;
        border-radius: 6px;
        background: var(--primary-color);
        color: white;
        text-decoration: none;
        transition: all 0.2s ease;
        font-size: 0.9rem;
    }

    .btn-accion:hover {
        background: #4f46e5;
        transform: scale(1.05);
    }

    .ver-btn {
        background: var(--primary-color);
    }

    /* ============================================
       MOBILE VIEW
       ============================================ */
    .cierres-mobile-view {
        display: none;
        gap: 1rem;
        flex-direction: column;
    }

    .cierre-mobile-card {
        background: var(--background-light);
        border-radius: 12px;
        padding: 1rem;
        border: 1px solid var(--border-color);
    }

    .mobile-card-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 1rem;
        padding-bottom: 1rem;
        border-bottom: 1px solid var(--border-color);
    }

    .mobile-card-title {
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
    }

    .mobile-card-title strong {
        font-size: 1rem;
        color: var(--text-primary);
    }

    .mobile-card-title small {
        font-size: 0.8rem;
        color: var(--text-secondary);
    }

    .mobile-card-content {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
        margin-bottom: 1rem;
    }

    .card-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-size: 0.9rem;
    }

    .card-label {
        color: var(--text-secondary);
        font-weight: 500;
    }

    .card-value {
        color: var(--text-primary);
        font-weight: 600;
    }

    .card-value.diferencia {
        font-weight: 700;
    }

    .card-value.diferencia.ganancia {
        color: #10b981;
    }

    .card-value.diferencia.perdida {
        color: #ef4444;
    }

    .card-value.diferencia.igual {
        color: var(--text-secondary);
    }

    .mobile-card-actions {
        display: flex;
        gap: 0.5rem;
    }

    .btn-mobile-ver {
        flex: 1;
        padding: 0.75rem;
        background: var(--primary-color);
        color: white;
        text-decoration: none;
        border-radius: 8px;
        text-align: center;
        font-weight: 600;
        font-size: 0.9rem;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        transition: all 0.2s ease;
    }

    .btn-mobile-ver:hover {
        background: #4f46e5;
    }

    /* ============================================
       EMPTY STATE
       ============================================ */
    .empty-state {
        text-align: center;
        padding: 3rem 1rem;
        color: var(--text-secondary);
    }

    .empty-state i {
        font-size: 3rem;
        color: var(--border-color);
        margin-bottom: 1rem;
    }

    .empty-state p {
        margin: 0.5rem 0;
        font-size: 1rem;
    }

    .empty-state-hint {
        font-size: 0.9rem;
        color: var(--text-secondary);
    }

    /* ============================================
       RESPONSIVE
       ============================================ */
    @media (max-width: 1024px) {
        .cierres-totales-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @media (max-width: 768px) {
        .cierres-totales-grid {
            grid-template-columns: 1fr;
        }

        .cierres-table-header {
            flex-direction: column;
            align-items: stretch;
        }

        .cierres-search-input {
            width: 100%;
        }

        .desktop-view {
            display: none;
        }

        .mobile-only {
            display: flex;
        }

        .cierres-main-title {
            font-size: 1.5rem;
        }

        .cierres-main-title i {
            font-size: 1.5rem;
        }
    }

    @media (max-width: 480px) {
        .cierres-header {
            padding: 1rem;
        }

        .cierres-main-title {
            font-size: 1.25rem;
            gap: 0.5rem;
        }

        .cierres-main-title i {
            font-size: 1.25rem;
        }

        .cierres-subtitle {
            font-size: 0.9rem;
        }

        .cierre-total-card {
            padding: 1rem;
            gap: 1rem;
        }

        .total-card-icon {
            width: 50px;
            height: 50px;
            font-size: 1.25rem;
        }

        .total-card-value {
            font-size: 1.5rem;
        }

        .cierres-table-container {
            padding: 1rem;
        }

        .cierres-table-header h2 {
            font-size: 1.1rem;
        }

        .cierre-mobile-card {
            padding: 0.875rem;
        }
    }
</style>

<script>
    // Cargar totales
    async function cargarTotales() {
        try {
            const response = await fetch('/administrador/cierres-caja/reportes/resumen');
            const data = await response.json();
            
            document.getElementById('totalSemanal').textContent = '$' + data.semanal.total.toFixed(2);
            document.getElementById('totalMensual').textContent = '$' + data.mensual.total.toFixed(2);
            document.getElementById('totalGlobal').textContent = '$' + data.global.total.toFixed(2);
        } catch (error) {
            console.error('Error cargando totales:', error);
        }
    }

    // Búsqueda en tiempo real
    document.getElementById('searchCierres').addEventListener('input', function(e) {
        const query = e.target.value.toLowerCase();
        const rows = document.querySelectorAll('.cierre-row');
        
        rows.forEach(row => {
            const text = row.textContent.toLowerCase();
            row.style.display = text.includes(query) ? '' : 'none';
        });
    });

    // Cargar totales al iniciar
    document.addEventListener('DOMContentLoaded', cargarTotales);
</script>
