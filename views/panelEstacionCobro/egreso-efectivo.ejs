<%- include('../partials/headerAdm.ejs'); %>
<%- include('../partials/flash.ejs'); %>

<div class="admin-dashboard">
    <div class="form-container">
        <!-- Breadcrumb -->
        <nav class="breadcrumb-nav">
            <a href="/administrador" class="breadcrumb-link">Dashboard</a>
            <span class="breadcrumb-separator">/</span>
            <a href="/administrador/estacionesdecobro" class="breadcrumb-link">Estaciones</a>
            <span class="breadcrumb-separator">/</span>
            <a href="/administrador/estacionesdecobro/<%= estacionDeCobro._id %>" class="breadcrumb-link"><%= estacionDeCobro.ubicacionDeEstacion %></a>
            <span class="breadcrumb-separator">/</span>
            <span class="breadcrumb-current">Egreso de Efectivo</span>
        </nav>

        <!-- Form Header -->
        <div class="form-header">
            <h1 class="form-title">➖ Egreso de Efectivo</h1>
            <p class="form-subtitle">Retira dinero de la caja durante su operación diaria</p>
        </div>

        <!-- Station Info Card -->
        <div class="transaction-info-card egreso">
            <div class="transaction-icon">💸</div>
            <div class="transaction-content">
                <p class="transaction-label">Estación de Cobro:</p>
                <h2 class="transaction-value"><%= estacionDeCobro.ubicacionDeEstacion %></h2>
            </div>
        </div>

        <!-- Warning Alert -->
        <div class="warning-alert">
            <span class="alert-icon">⚠️</span>
            <p class="alert-text">Registra cuidadosamente los egresos. Esto afectará el balance de la caja al momento del cierre.</p>
        </div>

        <!-- Form -->
        <form action="/administrador/estacionesdecobro/<%= estacionDeCobro._id %>/egreso-efectivo" method="POST" class="modern-form">
            <div class="form-grid">
                <!-- Dinero -->
                <div class="form-section">
                    <h3 class="section-title-form">💵 Monto a Retirar</h3>
                    
                    <div class="form-info-box warning-info">
                        <span class="info-box-icon">📝</span>
                        <p class="info-box-text">
                            Especifica el monto exacto que deseas retirar de la caja. 
                            Este egreso se registrará en el historial de la estación.
                        </p>
                    </div>

                    <div class="form-group-modern">
                        <label for="dineroDeEgreso" class="form-label-modern">Monto a Retirar *</label>
                        <div class="input-with-icon">
                            <span class="input-icon">💸</span>
                            <input type="number" 
                                   id="dineroDeEgreso" 
                                   name="dineroDeEgreso" 
                                   class="form-control-modern with-icon" 
                                   placeholder="0.00"
                                   step="0.01"
                                   min="0"
                                   required>
                        </div>
                        <small class="form-help">Ingresa solo números. Ej: 250.00</small>
                    </div>

                    <!-- Amount Preview -->
                    <div class="amount-preview egreso-preview">
                        <div class="preview-item">
                            <span class="preview-label">Monto a Retirar:</span>
                            <span class="preview-value output" id="previewAmount">$0.00</span>
                        </div>
                    </div>
                </div>

                <!-- Comentario -->
                <div class="form-section">
                    <h3 class="section-title-form">📝 Motivo del Egreso</h3>
                    
                    <div class="form-group-modern">
                        <label for="comentarioDeEgreso" class="form-label-modern">Comentario (Obligatorio) *</label>
                        <textarea id="comentarioDeEgreso" 
                                  name="comentarioDeEgreso" 
                                  class="form-control-modern textarea-modern" 
                                  placeholder="Ej: Retiro de efectivo, cambio, devolución, etc."
                                  rows="4"
                                  required></textarea>
                        <small class="form-help">Describe el motivo del egreso para el registro de auditoría</small>
                    </div>
                </div>
            </div>

            <!-- Form Actions -->
            <div class="form-actions">
                <a href="/administrador/estacionesdecobro/<%= estacionDeCobro._id %>" class="btn-secondary-modern">
                    ← Cancelar
                </a>
                <button type="submit" class="btn-danger-modern">
                    <span class="btn-icon">💾</span>
                    Registrar Egreso
                </button>
            </div>
        </form>
    </div>
</div>

<script>
// Actualizar preview del monto en tiempo real
const inputMonto = document.getElementById('dineroDeEgreso');
const previewAmount = document.getElementById('previewAmount');

function actualizarPreview() {
    const monto = parseFloat(inputMonto.value) || 0;
    previewAmount.textContent = '$' + monto.toFixed(2);
}

inputMonto.addEventListener('input', actualizarPreview);
inputMonto.addEventListener('change', actualizarPreview);
</script>

<%- include('../partials/footer.ejs'); %>