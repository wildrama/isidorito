<%- include('../partials/headerAdm.ejs'); %>
<%- include('../partials/flash.ejs'); %>

<div class="admin-dashboard">
    <div class="form-container">
        <!-- Breadcrumb -->
        <nav class="breadcrumb-nav">
            <a href="/administrador" class="breadcrumb-link">Dashboard</a>
            <span class="breadcrumb-separator">/</span>
            <a href="/administrador/estacionesdecobro" class="breadcrumb-link">Estaciones</a>
            <span class="breadcrumb-separator">/</span>
            <a href="/administrador/estacionesdecobro/<%= estacionDeCobro._id %>" class="breadcrumb-link"><%= estacionDeCobro.ubicacionDeEstacion %></a>
            <span class="breadcrumb-separator">/</span>
            <span class="breadcrumb-current">Ingreso Inicial</span>
        </nav>

        <!-- Form Header -->
        <div class="form-header">
            <h1 class="form-title">💵 Ingreso de Dinero Inicial</h1>
            <p class="form-subtitle">Abre la caja e ingresa el dinero disponible para el día</p>
        </div>

        <!-- Station Info Card -->
        <div class="estacion-info-opening">
            <div class="info-opening-icon">🏪</div>
            <div class="info-opening-content">
                <p class="info-opening-label">Estación de Cobro:</p>
                <h2 class="info-opening-value"><%= estacionDeCobro.ubicacionDeEstacion %></h2>
            </div>
        </div>

        <!-- Form -->
        <form action="/administrador/estacionesdecobro/<%= estacionDeCobro._id %>/ingreso-efectivo-inicio" method="POST" class="modern-form">
            <div class="form-grid">
                <!-- Información -->
                <div class="form-section">
                    <h3 class="section-title-form">💰 Monto de Apertura</h3>
                    
                    <div class="form-info-box">
                        <span class="info-box-icon">📝</span>
                        <p class="info-box-text">
                            Ingresa el dinero en efectivo que tendrá la caja al inicio del día. 
                            Este será el monto de referencia para los cálculos de cierre.
                        </p>
                    </div>

                    <div class="form-group-modern">
                        <label for="dineroDeIngresoInicio" class="form-label-modern">Monto Inicial de Caja *</label>
                        <div class="input-with-icon">
                            <span class="input-icon">💵</span>
                            <input type="number" 
                                   id="dineroDeIngresoInicio" 
                                   name="dineroDeIngresoInicio" 
                                   class="form-control-modern with-icon" 
                                   placeholder="0.00"
                                   step="0.01"
                                   min="0"
                                   required>
                        </div>
                        <small class="form-help">Ingresa solo números. Ej: 1000.50</small>
                    </div>

                    <!-- Amount Preview -->
                    <div class="amount-preview">
                        <div class="preview-item">
                            <span class="preview-label">Monto a Ingresar:</span>
                            <span class="preview-value" id="previewAmount">$0.00</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Form Actions -->
            <div class="form-actions">
                <a href="/administrador/estacionesdecobro/<%= estacionDeCobro._id %>" class="btn-secondary-modern">
                    ← Cancelar
                </a>
                <button type="submit" class="btn-primary-modern">
                    <span class="btn-icon">💾</span>
                    Abrir Caja e Ingresar Dinero
                </button>
            </div>
        </form>
    </div>
</div>

<script>
// Actualizar preview del monto en tiempo real
const inputMonto = document.getElementById('dineroDeIngresoInicio');
const previewAmount = document.getElementById('previewAmount');

function actualizarPreview() {
    const monto = parseFloat(inputMonto.value) || 0;
    previewAmount.textContent = '$' + monto.toFixed(2);
}

inputMonto.addEventListener('input', actualizarPreview);
inputMonto.addEventListener('change', actualizarPreview);
</script>

<%- include('../partials/footer.ejs'); %>