<%- include('../partials/headerAdm.ejs'); %>

<div class="admin-dashboard">
    <div class="page-header">
        <div class="page-header-content">
            <div>
                <h1 class="page-title">👥 Gestión de Usuarios</h1>
                <p class="page-subtitle">Total de usuarios: <%= cantidadDeUsuarios %></p>
            </div>
            <div class="page-actions">
                <a href="/administrador/userpanel/nuevousuario" class="btn-primary-modern">
                    <span class="btn-icon">+</span>
                    Nuevo Usuario
                </a>
            </div>
        </div>
    </div>

    <div class="users-grid-modern">
        <% if (usuariosTotales && usuariosTotales.length > 0) { %>
            <% usuariosTotales.forEach(usuario => { %>
            <div class="user-card-modern">
                <div class="user-card-header">
                    <div class="user-avatar-modern">
                        <span class="avatar-text"><%= usuario.username.charAt(0).toUpperCase() %></span>
                    </div>
                    <div class="user-status-badge status-active">Activo</div>
                </div>
                
                <div class="user-card-body">
                    <h3 class="user-name-modern"><%= usuario.username %></h3>
                    <div class="user-details-grid">
                        <% if (usuario.funcion) { %>
                        <div class="user-detail-item">
                            <span class="detail-icon">🏷️</span>
                            <div>
                                <p class="detail-label">Función</p>
                                <p class="detail-value"><%= usuario.funcion %></p>
                            </div>
                        </div>
                        <% } %>
                        <% if (usuario.email) { %>
                        <div class="user-detail-item">
                            <span class="detail-icon">📧</span>
                            <div>
                                <p class="detail-label">Email</p>
                                <p class="detail-value"><%= usuario.email %></p>
                            </div>
                        </div>
                        <% } %>
                    </div>
                </div>
                
                <div class="user-card-footer">
                    <a href="/administrador/userpanel/<%= usuario._id %>" class="btn-edit-full">
                        ⚙️ Opciones
                    </a>
                    <form action="/administrador/userpanel/<%= usuario._id %>?_method=DELETE" 
                          method="POST" 
                          style="flex: 1;"
                          onsubmit="return confirm('¿Estás seguro de eliminar al usuario <%= usuario.username %>?\n\nEsta acción no se puede deshacer.')">
                        <button type="submit" class="btn-delete-full">
                            🗑️ Eliminar
                        </button>
                    </form>
                </div>
            </div>
            <% }); %>
        <% } else { %>
            <div class="empty-state-full">
                <div class="empty-icon">👥</div>
                <h3>No hay usuarios registrados</h3>
                <p>Crea el primer usuario del sistema</p>
                <a href="/administrador/userpanel/nuevousuario" class="btn-primary-modern">
                    <span class="btn-icon">+</span>
                    Crear Primer Usuario
                </a>
            </div>
        <% } %>
    </div>
</div>

<%- include('../partials/footer.ejs'); %>
