<!-- PRODUCT SEARCH INPUT - Componente reutilizable -->
<!-- 
Uso simple:
    <%- include('../partials/productSearchInput', {
        inputId: 'productInput',
        resultsId: 'productResults',
        selectedProductId: 'selectedProductId'
    }) %>
-->

<div class="product-search-widget">
    <!-- Input de búsqueda -->
    <div class="search-input-wrapper mb-2">
        <div class="input-group">
            <span class="input-group-text">🔍</span>
            <input type="text" 
                   id="<%= inputId || 'productSearchInput' %>" 
                   class="form-control" 
                   placeholder="Buscar producto..."
                   autocomplete="off">
            <button type="button" 
                    class="btn btn-outline-secondary"
                    id="<%= inputId %>_clear"
                    style="display: none;">
                ✕
            </button>
        </div>
    </div>

    <!-- Dropdown de resultados -->
    <div id="<%= resultsId || 'productSearchResults' %>" 
         class="product-search-dropdown"
         style="display: none;">
    </div>

    <!-- Hidden input para producto seleccionado -->
    <input type="hidden" 
           id="<%= selectedProductId || 'selectedProductId' %>" 
           name="productId">
    
    <!-- Info del producto seleccionado -->
    <div id="<%= selectedProductId || 'selectedProductId' %>_info" 
         class="product-info-selected"
         style="display: none;">
    </div>
</div>

<style>
.product-search-widget {
    position: relative;
    width: 100%;
}

.search-input-wrapper {
    position: relative;
}

.product-search-dropdown {
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    background: white;
    border: 1px solid #dee2e6;
    border-radius: 0.375rem;
    max-height: 300px;
    overflow-y: auto;
    z-index: 1000;
    box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.15);
}

.product-search-item {
    padding: 0.75rem 1rem;
    cursor: pointer;
    border-bottom: 1px solid #f0f0f0;
    transition: background-color 0.15s;
}

.product-search-item:hover {
    background-color: #f8f9fa;
}

.product-search-item:last-child {
    border-bottom: none;
}

.product-info-selected {
    padding: 1rem;
    background-color: #e7f3ff;
    border: 1px solid #b3d9ff;
    border-radius: 0.375rem;
    margin-top: 0.5rem;
}

.product-info-name {
    font-weight: 600;
    color: #0c5aa0;
}

.product-info-details {
    font-size: 0.875rem;
    color: #656565;
    margin-top: 0.25rem;
}
</style>

<script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
<script src="/js/searchManager.js"></script>

<script>
(function() {
    const inputId = '<%= inputId ? inputId : "productSearchInput" %>';
    const resultsId = '<%= resultsId ? resultsId : "productSearchResults" %>';
    const selectedProductId = '<%= selectedProductId ? selectedProductId : "selectedProductId" %>';

    const input = document.getElementById(inputId);
    const resultsDiv = document.getElementById(resultsId);
    const selectedInput = document.getElementById(selectedProductId);
    const selectedInfo = document.getElementById(selectedProductId + '_info');
    const clearBtn = document.getElementById(inputId + '_clear');

    // Crear gestor de búsqueda
    const searchManager = new SearchManager({
        endpoint: '/api/search/smart',
        debounceDelay: 300,
        minChars: 1,
        onSuccess: (productos) => {
            displayResults(productos);
        },
        onError: (message) => {
            resultsDiv.innerHTML = '<div class="product-search-item text-muted">' + (message || 'Error en búsqueda') + '</div>';
            resultsDiv.style.display = 'block';
        },
        onLoading: (isLoading) => {
            if (isLoading) {
                resultsDiv.innerHTML = '<div class="product-search-item text-center"><span class="spinner-border spinner-border-sm"></span> Buscando...</div>';
                resultsDiv.style.display = 'block';
            }
        }
    });

    // Input focus y cambio
    input.addEventListener('input', function() {
        const value = this.value.trim();
        
        if (value.length === 0) {
            resultsDiv.style.display = 'none';
            clearBtn.style.display = 'none';
            return;
        }

        clearBtn.style.display = 'block';
        searchManager.search(value);
    });

    // Clear button
    clearBtn.addEventListener('click', function() {
        input.value = '';
        resultsDiv.style.display = 'none';
        clearBtn.style.display = 'none';
        selectedInput.value = '';
        selectedInfo.style.display = 'none';
        searchManager.clear();
        input.focus();
    });

    // Cerrar resultados al hacer click fuera
    document.addEventListener('click', function(e) {
        if (!input.contains(e.target) && !resultsDiv.contains(e.target)) {
            resultsDiv.style.display = 'none';
        }
    });

    // Enter para búsqueda inmediata
    input.addEventListener('keypress', function(e) {
        if (e.key === 'Enter') {
            e.preventDefault();
            searchManager.searchNow(this.value);
        }
    });

    // Mostrar resultados
    function displayResults(productos) {
        resultsDiv.innerHTML = '';

        if (!productos || productos.length === 0) {
            resultsDiv.innerHTML = '<div class="product-search-item text-muted">No encontrado</div>';
            resultsDiv.style.display = 'block';
            return;
        }

        productos.forEach(producto => {
            const item = document.createElement('div');
            item.className = 'product-search-item';
            item.innerHTML = `
                <div class="fw-bold">${producto.nombre}</div>
                <small class="text-muted">
                    ${producto.marca || 'S/M'} • 
                    Código: ${producto.codigo || 'N/A'} • 
                    $${(producto.precioMinorista || 0).toFixed(2)}
                </small>
            `;
            
            item.addEventListener('click', () => selectProduct(producto));
            resultsDiv.appendChild(item);
        });

        resultsDiv.style.display = 'block';
    }

    // Seleccionar producto
    function selectProduct(producto) {
        input.value = producto.nombre;
        selectedInput.value = producto._id;
        resultsDiv.style.display = 'none';
        clearBtn.style.display = 'block';
        searchManager.clear();

        // Mostrar info del producto seleccionado
        selectedInfo.innerHTML = `
            <div class="product-info-name">${producto.nombre}</div>
            <div class="product-info-details">
                Marca: ${producto.marca || 'N/A'} | 
                Código: ${producto.codigo || 'N/A'} | 
                Stock: ${producto.cantidad || 0} | 
                Precio: $${(producto.precioMinorista || 0).toFixed(2)}
            </div>
        `;
        selectedInfo.style.display = 'block';

        // Disparar evento personalizado
        const event = new CustomEvent('productSelected', { 
            detail: { producto, inputId, selectedProductId } 
        });
        document.dispatchEvent(event);
    }
})();
</script>
