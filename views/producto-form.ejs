<%- include('./partials/headerAdm.ejs'); %>

<%- include('./partials/flash.ejs'); %>

<div class="admin-dashboard">
    <div class="form-container">
        <!-- Breadcrumb -->
        <nav class="breadcrumb-nav">
            <a href="/administrador" class="breadcrumb-link">Dashboard</a>
            <span class="breadcrumb-separator">/</span>
            <a href="/administrador/productos" class="breadcrumb-link">Productos</a>
            <span class="breadcrumb-separator">/</span>
            <span class="breadcrumb-current"><%= producto ? 'Editar' : 'Nuevo' %></span>
        </nav>

        <!-- Form Header -->
        <div class="form-header">
            <h1 class="form-title">
                <%= producto ? '✏️ Editar Producto' : '➕ Nuevo Producto' %>
            </h1>
            <p class="form-subtitle">
                <%= producto ? 'Modifica la información del producto' : 'Completa los datos del nuevo producto' %>
            </p>
        </div>

        <!-- Form -->
        <form action="<%= producto ? `/administrador/productos/editar/${producto._id}?_method=PUT` : '/administrador/productos/nuevo' %>" 
              method="POST" 
              enctype="multipart/form-data" 
              class="modern-form">
            
            <div class="form-grid">
                <!-- Información Básica -->
                <div class="form-section">
                    <h3 class="section-title-form">📝 Información Básica</h3>
                    
                    <div class="form-group-modern">
                        <label for="nombre" class="form-label-modern">Nombre del Producto *</label>
                        <input type="text" 
                               id="nombre" 
                               name="nombre" 
                               class="form-control-modern" 
                               placeholder="Ej: Laptop HP Pavilion"
                               value="<%= producto ? producto.nombre : '' %>"
                               required>
                    </div>

                    <div class="form-group-modern">
                        <label for="categoria" class="form-label-modern">Categoría *</label>
                        <select id="categoria" name="categoria" class="form-control-modern" required>
                            <option value="">Selecciona una categoría</option>
                            <% categorias.forEach(cat => { %>
                                <option value="<%= cat.nombre %>" 
                                        <%= producto && producto.categoria === cat.nombre ? 'selected' : '' %>>
                                    <%= cat.nombre %>
                                </option>
                            <% }); %>
                        </select>
                    </div>

                    <div class="form-row">
                        <div class="form-group-modern">
                            <label for="precio" class="form-label-modern">Precio *</label>
                            <div class="input-with-icon">
                                <span class="input-icon">$</span>
                                <input type="number" 
                                       id="precio" 
                                       name="precio" 
                                       class="form-control-modern with-icon" 
                                       placeholder="0.00"
                                       step="0.01"
                                       value="<%= producto ? producto.precio : '' %>"
                                       required>
                            </div>
                        </div>

                        <div class="form-group-modern">
                            <label for="stock" class="form-label-modern">Stock *</label>
                            <div class="input-with-icon">
                                <span class="input-icon">📦</span>
                                <input type="number" 
                                       id="stock" 
                                       name="stock" 
                                       class="form-control-modern with-icon" 
                                       placeholder="0"
                                       value="<%= producto ? producto.stock : '' %>"
                                       required>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Imagen -->
                <div class="form-section">
                    <h3 class="section-title-form">🖼️ Imagen del Producto</h3>
                    
                    <div class="form-group-modern">
                        <label for="imagen" class="form-label-modern">
                            <%= producto ? 'Cambiar Imagen (opcional)' : 'Subir Imagen' %>
                        </label>
                        <div class="file-upload-wrapper">
                            <input type="file" 
                                   id="imagen" 
                                   name="imagen" 
                                   class="file-input" 
                                   accept="image/*"
                                   onchange="previewImage(event)">
                            <label for="imagen" class="file-label">
                                <span class="file-icon">📁</span>
                                <span class="file-text">Seleccionar archivo</span>
                            </label>
                        </div>
                        
                        <div id="imagePreview" class="image-preview">
                            <% if (producto && producto.imagen) { %>
                                <img src="<%= producto.imagen %>" alt="Preview" class="preview-img">
                            <% } %>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Form Actions -->
            <div class="form-actions">
                <a href="/administrador/productos" class="btn-secondary-modern">
                    Cancelar
                </a>
                <button type="submit" class="btn-primary-modern">
                    <span class="btn-icon">💾</span>
                    <%= producto ? 'Guardar Cambios' : 'Crear Producto' %>
                </button>
            </div>
        </form>
    </div>
</div>

<script>
function previewImage(event) {
    const preview = document.getElementById('imagePreview');
    const file = event.target.files[0];
    const fileText = document.querySelector('.file-text');
    
    if (file) {
        fileText.textContent = file.name;
        const reader = new FileReader();
        
        reader.onload = function(e) {
            preview.innerHTML = `<img src="${e.target.result}" alt="Preview" class="preview-img">`;
        }
        
        reader.readAsDataURL(file);
    }
}
</script>

<%- include('./partials/footer.ejs'); %>
