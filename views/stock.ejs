<%- include('./partials/headerAdm.ejs'); %>

<%- include('./partials/flash.ejs'); %>

<div class="admin-dashboard">
    <!-- Header Section -->
    <div class="page-header">
        <div class="page-header-content">
            <div>
                <h1 class="page-title">📊 Control de Stock</h1>
                <p class="page-subtitle">Monitorea el inventario en tiempo real</p>
            </div>
            <div class="page-actions">
                <a href="/administrador/productos/nuevo" class="btn-primary-modern">
                    <span class="btn-icon">+</span>
                    Agregar Producto
                </a>
            </div>
        </div>
    </div>

    <!-- Stock Stats -->
    <div class="stats-mini-grid">
        <div class="stat-mini-card">
            <div class="stat-mini-icon" style="background: rgba(99, 102, 241, 0.1); color: #6366f1;">📦</div>
            <div>
                <p class="stat-mini-label">Total Productos</p>
                <h3 class="stat-mini-value"><%= productos.length %></h3>
            </div>
        </div>
        <div class="stat-mini-card">
            <div class="stat-mini-icon" style="background: rgba(16, 185, 129, 0.1); color: #10b981;">✓</div>
            <div>
                <p class="stat-mini-label">Stock Total</p>
                <h3 class="stat-mini-value"><%= productos.reduce((sum, p) => sum + p.stock, 0) %></h3>
            </div>
        </div>
        <div class="stat-mini-card">
            <div class="stat-mini-icon" style="background: rgba(245, 158, 11, 0.1); color: #f59e0b;">⚠️</div>
            <div>
                <p class="stat-mini-label">Stock Bajo</p>
                <h3 class="stat-mini-value"><%= productos.filter(p => p.stock > 0 && p.stock < 10).length %></h3>
            </div>
        </div>
        <div class="stat-mini-card">
            <div class="stat-mini-icon" style="background: rgba(239, 68, 68, 0.1); color: #ef4444;">✕</div>
            <div>
                <p class="stat-mini-label">Sin Stock</p>
                <h3 class="stat-mini-value"><%= productos.filter(p => p.stock === 0).length %></h3>
            </div>
        </div>
    </div>

    <!-- Filters -->
    <div class="filters-card">
        <div class="filters-row">
            <div class="search-box">
                <span class="search-icon">🔍</span>
                <input type="text" 
                       id="searchInput" 
                       placeholder="Buscar por nombre o categoría..." 
                       class="search-input"
                       onkeyup="filterStock()">
            </div>
            <select id="stockFilter" class="filter-select" onchange="filterStock()">
                <option value="">Todos los niveles</option>
                <option value="out">Sin stock (0)</option>
                <option value="critical">Crítico (1-5)</option>
                <option value="low">Bajo (6-10)</option>
                <option value="ok">Normal (11-50)</option>
                <option value="high">Alto (50+)</option>
            </select>
        </div>
    </div>

    <!-- Stock Table -->
    <div class="stock-table-container">
        <table class="stock-table">
            <thead>
                <tr>
                    <th>Producto</th>
                    <th>Categoría</th>
                    <th class="text-center">Stock Actual</th>
                    <th class="text-center">Estado</th>
                    <th>Precio</th>
                    <th class="text-right">Acciones</th>
                </tr>
            </thead>
            <tbody id="stockTableBody">
                <% productos.forEach(producto => { %>
                <tr class="stock-row" 
                    data-nombre="<%= producto.nombre.toLowerCase() %>"
                    data-categoria="<%= producto.categoria.toLowerCase() %>"
                    data-stock="<%= producto.stock %>">
                    <td>
                        <div class="product-cell">
                            <% if (producto.imagen) { %>
                                <img src="<%= producto.imagen %>" alt="<%= producto.nombre %>" class="product-thumb">
                            <% } else { %>
                                <div class="product-thumb-placeholder">📦</div>
                            <% } %>
                            <span class="product-name-table"><%= producto.nombre %></span>
                        </div>
                    </td>
                    <td>
                        <span class="category-badge"><%= producto.categoria %></span>
                    </td>
                    <td class="text-center">
                        <div class="stock-value-wrapper">
                            <span class="stock-number <%= producto.stock === 0 ? 'text-danger' : (producto.stock < 10 ? 'text-warning' : '') %>">
                                <%= producto.stock %>
                            </span>
                            <span class="stock-unit">unidades</span>
                        </div>
                    </td>
                    <td class="text-center">
                        <% if (producto.stock === 0) { %>
                            <span class="stock-badge-table badge-danger">Sin stock</span>
                        <% } else if (producto.stock <= 5) { %>
                            <span class="stock-badge-table badge-critical">Crítico</span>
                        <% } else if (producto.stock < 10) { %>
                            <span class="stock-badge-table badge-warning">Bajo</span>
                        <% } else if (producto.stock <= 50) { %>
                            <span class="stock-badge-table badge-success">Normal</span>
                        <% } else { %>
                            <span class="stock-badge-table badge-info">Alto</span>
                        <% } %>
                    </td>
                    <td>
                        <span class="price-table">$<%= producto.precio.toFixed(2) %></span>
                    </td>
                    <td class="text-right">
                        <div class="table-actions">
                            <a href="/administrador/productos/editar/<%= producto._id %>" 
                               class="btn-table-action btn-edit-action"
                               title="Editar">
                                ✏️
                            </a>
                            <button onclick="quickStockUpdate('<%= producto._id %>', '<%= producto.nombre %>', <%= producto.stock %>)" 
                                    class="btn-table-action btn-stock-action"
                                    title="Actualizar stock">
                                📦
                            </button>
                        </div>
                    </td>
                </tr>
                <% }); %>
            </tbody>
        </table>

        <% if (productos.length === 0) { %>
        <div class="empty-state-table">
            <div class="empty-icon">📦</div>
            <h3>No hay productos en el inventario</h3>
            <a href="/administrador/productos/nuevo" class="btn-primary-modern">
                <span class="btn-icon">+</span>
                Agregar Primer Producto
            </a>
        </div>
        <% } %>

        <div id="noResults" class="empty-state-table" style="display: none;">
            <div class="empty-icon">🔍</div>
            <h3>No se encontraron productos</h3>
            <button onclick="clearStockFilters()" class="btn-secondary-modern">
                Limpiar filtros
            </button>
        </div>
    </div>
</div>

<!-- Modal para actualización rápida de stock -->
<div id="stockModal" class="modal-overlay" style="display: none;">
    <div class="modal-content-stock">
        <div class="modal-header-stock">
            <h3>📦 Actualizar Stock</h3>
            <button onclick="closeStockModal()" class="modal-close">✕</button>
        </div>
        <div class="modal-body-stock">
            <p class="modal-product-name" id="modalProductName"></p>
            <div class="stock-update-form">
                <div class="form-group-modern">
                    <label class="form-label-modern">Stock Actual</label>
                    <input type="number" id="currentStock" class="form-control-modern" readonly>
                </div>
                <div class="form-group-modern">
                    <label class="form-label-modern">Nuevo Stock</label>
                    <input type="number" id="newStock" class="form-control-modern" min="0" required>
                </div>
            </div>
        </div>
        <div class="modal-footer-stock">
            <button onclick="closeStockModal()" class="btn-secondary-modern">Cancelar</button>
            <button onclick="saveStockUpdate()" class="btn-primary-modern">
                <span class="btn-icon">💾</span>
                Guardar
            </button>
        </div>
    </div>
</div>

<script>
let currentProductId = null;

function filterStock() {
    const searchValue = document.getElementById('searchInput').value.toLowerCase();
    const stockValue = document.getElementById('stockFilter').value;
    const rows = document.querySelectorAll('.stock-row');
    const noResults = document.getElementById('noResults');
    let visibleCount = 0;
    
    rows.forEach(row => {
        const nombre = row.dataset.nombre;
        const categoria = row.dataset.categoria;
        const stock = parseInt(row.dataset.stock);
        
        const matchesSearch = nombre.includes(searchValue) || categoria.includes(searchValue);
        
        let matchesStock = true;
        if (stockValue === 'out') matchesStock = stock === 0;
        else if (stockValue === 'critical') matchesStock = stock > 0 && stock <= 5;
        else if (stockValue === 'low') matchesStock = stock > 5 && stock <= 10;
        else if (stockValue === 'ok') matchesStock = stock > 10 && stock <= 50;
        else if (stockValue === 'high') matchesStock = stock > 50;
        
        if (matchesSearch && matchesStock) {
            row.style.display = '';
            visibleCount++;
        } else {
            row.style.display = 'none';
        }
    });
    
    noResults.style.display = (visibleCount === 0 && rows.length > 0) ? 'flex' : 'none';
}

function clearStockFilters() {
    document.getElementById('searchInput').value = '';
    document.getElementById('stockFilter').value = '';
    filterStock();
}

function quickStockUpdate(productId, productName, currentStock) {
    currentProductId = productId;
    document.getElementById('modalProductName').textContent = productName;
    document.getElementById('currentStock').value = currentStock;
    document.getElementById('newStock').value = currentStock;
    document.getElementById('stockModal').style.display = 'flex';
}

function closeStockModal() {
    document.getElementById('stockModal').style.display = 'none';
    currentProductId = null;
}

function saveStockUpdate() {
    const newStock = document.getElementById('newStock').value;
    if (currentProductId && newStock !== '') {
        // Aquí iría la llamada AJAX para actualizar el stock
        // Por ahora, recargamos la página
        window.location.href = `/administrador/productos/editar/${currentProductId}`;
    }
}

// Cerrar modal al hacer clic fuera
document.getElementById('stockModal')?.addEventListener('click', function(e) {
    if (e.target === this) {
        closeStockModal();
    }
});
</script>

<%- include('./partials/footer.ejs'); %>
