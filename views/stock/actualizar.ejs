<%- include('../partials/headerAdm.ejs'); %>

<div class="admin-dashboard">
    <div class="form-container">
        <!-- Breadcrumb -->
        <nav class="breadcrumb-nav">
            <a href="/administrador" class="breadcrumb-link">Dashboard</a>
            <span class="breadcrumb-separator">/</span>
            <a href="/administrador/stock" class="breadcrumb-link">Stock</a>
            <span class="breadcrumb-separator">/</span>
            <span class="breadcrumb-current">Actualizar Stock</span>
        </nav>

        <!-- Page Header -->
        <div class="form-header">
            <h1 class="form-title">📦 Actualizar Stock</h1>
            <p class="form-subtitle">Busca un producto y actualiza su cantidad disponible</p>
        </div>

        <!-- Main Form -->
        <form id="updateStockForm" class="stock-update-form">
            <!-- Product Search Section -->
            <div class="card mb-4">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">Paso 1: Buscar Producto</h5>
                </div>
                <div class="card-body">
                    <!-- Product Search Input Component -->
                    <%- include('../partials/productSearchInput', {
                        inputId: 'stockProductSearch',
                        resultsId: 'stockResults',
                        selectedProductId: 'selectedProductId'
                    }) %>
                </div>
            </div>

            <!-- Stock Update Section -->
            <div class="card mb-4">
                <div class="card-header bg-info text-white">
                    <h5 class="mb-0">Paso 2: Actualizar Cantidad</h5>
                </div>
                <div class="card-body">
                    <!-- Current Stock Display -->
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <div class="stock-info-box">
                                <label class="form-label">Stock Actual</label>
                                <div class="stock-value" id="currentStock">
                                    <span class="badge bg-warning text-dark">Selecciona un producto</span>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="stock-info-box">
                                <label class="form-label">Precio Unitario</label>
                                <div class="stock-value" id="unitPrice">
                                    <span class="badge bg-secondary">$0.00</span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Update Type Selection -->
                    <div class="mb-3">
                        <label class="form-label">Tipo de Actualización</label>
                        <div class="btn-group w-100" role="group">
                            <input type="radio" class="btn-check" name="updateType" id="setAmount" value="set" checked>
                            <label class="btn btn-outline-primary" for="setAmount">
                                Establecer cantidad
                            </label>

                            <input type="radio" class="btn-check" name="updateType" id="addAmount" value="add">
                            <label class="btn btn-outline-primary" for="addAmount">
                                Agregar cantidad
                            </label>

                            <input type="radio" class="btn-check" name="updateType" id="subtractAmount" value="subtract">
                            <label class="btn btn-outline-danger" for="subtractAmount">
                                Restar cantidad
                            </label>
                        </div>
                    </div>

                    <!-- New/Change Amount Input -->
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="newQuantity" class="form-label" id="quantityLabel">
                                    Nueva Cantidad
                                </label>
                                <input type="number" 
                                       id="newQuantity" 
                                       name="quantity" 
                                       class="form-control form-control-lg"
                                       placeholder="0"
                                       min="0"
                                       step="1"
                                       required>
                                <small class="form-text text-muted" id="quantityHint">
                                    Ingresa la nueva cantidad total
                                </small>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="notes" class="form-label">Notas (Opcional)</label>
                                <input type="text" 
                                       id="notes" 
                                       name="notes" 
                                       class="form-control"
                                       placeholder="ej: Reposición, Devolución, etc.">
                            </div>
                        </div>
                    </div>

                    <!-- Preview of Change -->
                    <div id="changePreview" class="alert alert-info" style="display: none;">
                        <strong>Cambio estimado:</strong>
                        <div id="changePreviewText"></div>
                    </div>
                </div>
            </div>

            <!-- Action Buttons -->
            <div class="form-actions">
                <button type="submit" class="btn btn-success btn-lg" id="submitBtn" disabled>
                    ✓ Actualizar Stock
                </button>
                <a href="/administrador/stock" class="btn btn-secondary btn-lg">
                    ← Cancelar
                </a>
            </div>

            <!-- Hidden inputs -->
            <input type="hidden" id="selectedProductId" name="productId">
        </form>
    </div>
</div>

<!-- Styles -->
<style>
.admin-dashboard {
    padding: 2rem;
    background-color: #f5f5f5;
    min-height: 100vh;
}

.stock-info-box {
    padding: 1rem;
    background-color: #f8f9fa;
    border-radius: 0.375rem;
    border-left: 4px solid #0d6efd;
}

.stock-value {
    font-size: 1.25rem;
    font-weight: 600;
    margin-top: 0.5rem;
}

.form-actions {
    display: flex;
    gap: 1rem;
    margin-top: 2rem;
}

.form-actions button,
.form-actions a {
    flex: 1;
}

.card {
    box-shadow: 0 0.125rem 0.25rem rgba(0, 0, 0, 0.075);
    border: none;
    margin-bottom: 1.5rem;
}

.card-header {
    border-bottom: 1px solid rgba(0, 0, 0, 0.125);
    padding: 1rem 1.25rem;
}

.card-body {
    padding: 1.5rem;
}
</style>

<!-- JavaScript -->
<script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
<script src="/js/productSearch.js"></script>

<script>
(function() {
    const form = document.getElementById('updateStockForm');
    const selectedProductInput = document.getElementById('selectedProductId');
    const newQuantityInput = document.getElementById('newQuantity');
    const notesInput = document.getElementById('notes');
    const submitBtn = document.getElementById('submitBtn');
    const currentStockDiv = document.getElementById('currentStock');
    const unitPriceDiv = document.getElementById('unitPrice');
    const changePreview = document.getElementById('changePreview');
    const changePreviewText = document.getElementById('changePreviewText');
    const updateTypeRadios = document.querySelectorAll('input[name="updateType"]');
    const quantityLabel = document.getElementById('quantityLabel');
    const quantityHint = document.getElementById('quantityHint');

    let selectedProduct = null;

    // Escuchar selección de producto
    document.addEventListener('productSelected', function(e) {
        if (e.detail.selectedProductId === 'selectedProductId') {
            selectedProduct = e.detail.producto;
            currentStockDiv.innerHTML = `
                <span class="badge bg-success">${selectedProduct.cantidad || 0} unidades</span>
            `;
            unitPriceDiv.innerHTML = `
                <span class="badge bg-info">$${(selectedProduct.precioMinorista || 0).toFixed(2)}</span>
            `;
            submitBtn.disabled = false;
            newQuantityInput.value = '';
            updateTypeRadios[0].checked = true;
            updateTypeRadios[0].dispatchEvent(new Event('change'));
            updatePreview();
        }
    });

    // Cambiar etiqueta según tipo de actualización
    updateTypeRadios.forEach(radio => {
        radio.addEventListener('change', function() {
            switch(this.value) {
                case 'set':
                    quantityLabel.textContent = 'Nueva Cantidad';
                    quantityHint.textContent = 'Ingresa la nueva cantidad total';
                    break;
                case 'add':
                    quantityLabel.textContent = 'Cantidad a Agregar';
                    quantityHint.textContent = 'Ingresa la cantidad a sumar al stock actual';
                    break;
                case 'subtract':
                    quantityLabel.textContent = 'Cantidad a Restar';
                    quantityHint.textContent = 'Ingresa la cantidad a restar del stock actual';
                    break;
            }
            updatePreview();
        });
    });

    // Mostrar preview del cambio
    newQuantityInput.addEventListener('input', updatePreview);

    function updatePreview() {
        if (!selectedProduct || !newQuantityInput.value) {
            changePreview.style.display = 'none';
            return;
        }

        const updateType = document.querySelector('input[name="updateType"]:checked').value;
        const currentQty = selectedProduct.cantidad || 0;
        const inputQty = parseInt(newQuantityInput.value) || 0;
        let newQty, change;

        switch(updateType) {
            case 'set':
                newQty = inputQty;
                change = inputQty - currentQty;
                changePreviewText.innerHTML = `
                    ${currentQty} → ${newQty} unidades
                    <span class="${change > 0 ? 'text-success' : change < 0 ? 'text-danger' : 'text-muted'}">
                        (${change > 0 ? '+' : ''}${change})
                    </span>
                `;
                break;
            case 'add':
                newQty = currentQty + inputQty;
                changePreviewText.innerHTML = `
                    ${currentQty} + ${inputQty} = ${newQty} unidades
                    <span class="text-success">(+${inputQty})</span>
                `;
                break;
            case 'subtract':
                newQty = Math.max(0, currentQty - inputQty);
                changePreviewText.innerHTML = `
                    ${currentQty} - ${inputQty} = ${newQty} unidades
                    <span class="text-danger">(-${inputQty})</span>
                `;
                break;
        }

        changePreview.style.display = 'block';
    }

    // Enviar formulario
    form.addEventListener('submit', async function(e) {
        e.preventDefault();

        if (!selectedProduct) {
            alert('Por favor selecciona un producto');
            return;
        }

        const updateType = document.querySelector('input[name="updateType"]:checked').value;
        const currentQty = selectedProduct.cantidad || 0;
        const inputQty = parseInt(newQuantityInput.value) || 0;
        let newQty;

        switch(updateType) {
            case 'set':
                newQty = inputQty;
                break;
            case 'add':
                newQty = currentQty + inputQty;
                break;
            case 'subtract':
                newQty = Math.max(0, currentQty - inputQty);
                break;
        }

        try {
            submitBtn.disabled = true;
            submitBtn.innerHTML = '⏳ Guardando...';

            // Enviar datos al servidor
            const response = await axios.post('/administrador/stock/update', {
                productId: selectedProduct._id,
                cantidad: newQty,
                updateType: updateType,
                notes: notesInput.value || ''
            });

            if (response.data.success) {
                alert('✓ Stock actualizado correctamente');
                // Redirigir o limpiar formulario
                setTimeout(() => {
                    window.location.href = '/administrador/stock';
                }, 1000);
            } else {
                alert('Error: ' + response.data.message);
                submitBtn.disabled = false;
                submitBtn.innerHTML = '✓ Actualizar Stock';
            }
        } catch (error) {
            console.error('Error:', error);
            alert('Error al actualizar stock: ' + (error.response?.data?.message || error.message));
            submitBtn.disabled = false;
            submitBtn.innerHTML = '✓ Actualizar Stock';
        }
    });
})();
</script>
