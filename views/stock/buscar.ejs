<%- include('../partials/headerAdm.ejs'); %>

<div class="admin-dashboard">
    <div class="form-container">
        <!-- Breadcrumb -->
        <nav class="breadcrumb-nav">
            <a href="/administrador" class="breadcrumb-link">Dashboard</a>
            <span class="breadcrumb-separator">/</span>
            <a href="/administrador/stock" class="breadcrumb-link">Stock</a>
            <span class="breadcrumb-separator">/</span>
            <span class="breadcrumb-current">Búsqueda de Productos</span>
        </nav>

        <!-- Search Header -->
        <div class="form-header">
            <h1 class="form-title">🔍 Buscar Productos</h1>
            <p class="form-subtitle">Encuentra productos por nombre, marca o código de barra</p>
        </div>

        <!-- Search Container -->
        <div class="search-container">
            <div class="search-box-large">
                <span class="search-icon-large">🔍</span>
                <input type="text" 
                       id="searchInput" 
                       class="search-input-large" 
                       placeholder="Busca por nombre, marca o código de barra..."
                       autocomplete="off">
            </div>

            <!-- Search Type Toggle -->
            <div class="search-type-wrapper" style="margin-top: 1rem; display: flex; gap: 1rem; align-items: center;">
                <label style="margin: 0;">
                    <input type="checkbox" id="searchByBarcode">
                    Modo Código de Barra
                </label>
                <button id="searchBtn" class="btn btn-primary" style="padding: 0.5rem 1.5rem; cursor: pointer;">
                    🔍 Buscar
                </button>
            </div>

            <!-- Results Container -->
            <div id="searchResults" class="search-results" style="display: none; margin-top: 2rem;">
                <div id="resultsContent" class="results-grid"></div>
            </div>

            <!-- No Results -->
            <div id="noResults" class="alert alert-info" style="display: none; margin-top: 2rem;">
                No se encontraron productos
            </div>
        </div>
    </div>
</div>

<!-- Styles -->
<style>
.admin-dashboard {
    padding: 2rem;
    background-color: #f5f5f5;
    min-height: 100vh;
}

.form-container {
    max-width: 800px;
    margin: 0 auto;
    background: white;
    padding: 2rem;
    border-radius: 0.5rem;
    box-shadow: 0 0.125rem 0.25rem rgba(0, 0, 0, 0.075);
}

.breadcrumb-nav {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 2rem;
}

.breadcrumb-link {
    color: #0d6efd;
    text-decoration: none;
}

.breadcrumb-link:hover {
    text-decoration: underline;
}

.breadcrumb-separator {
    color: #666;
    margin: 0 0.5rem;
}

.breadcrumb-current {
    color: #666;
    font-weight: 500;
}

.form-header {
    margin-bottom: 2rem;
}

.form-title {
    font-size: 2rem;
    font-weight: 600;
    color: #333;
    margin-bottom: 0.5rem;
}

.form-subtitle {
    color: #666;
    font-size: 1rem;
}

.search-box-large {
    display: flex;
    align-items: center;
    background-color: #f8f9fa;
    border: 2px solid #0d6efd;
    border-radius: 0.5rem;
    padding: 1rem;
    transition: all 0.3s ease;
}

.search-box-large.active {
    border-color: #7c3aed;
    box-shadow: 0 0 0 3px rgba(124, 58, 237, 0.1);
}

.search-input-large {
    flex: 1;
    border: none;
    background: transparent;
    font-size: 1.1rem;
    outline: none;
}

.search-type-wrapper {
    padding: 1rem;
    background-color: #f8f9fa;
    border-radius: 0.5rem;
}

.search-results {
    border: 1px solid #dee2e6;
    border-radius: 0.5rem;
    padding: 1rem;
    background: white;
}

.results-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
    gap: 1rem;
}

.product-card {
    border: 1px solid #dee2e6;
    border-radius: 0.5rem;
    padding: 1rem;
    cursor: pointer;
    transition: all 0.3s;
}

.product-card:hover {
    box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.15);
    transform: translateY(-2px);
    border-color: #0d6efd;
}

.product-name {
    font-weight: 600;
    margin-bottom: 0.5rem;
    color: #333;
}

.product-details {
    font-size: 0.875rem;
    color: #666;
    line-height: 1.5;
}

.product-price {
    font-weight: 600;
    color: #0d6efd;
    margin-top: 0.5rem;
}

.btn-primary {
    background-color: #0d6efd;
    border-color: #0d6efd;
    color: white;
    border-radius: 0.375rem;
    font-weight: 500;
    transition: all 0.2s;
}

.btn-primary:hover {
    background-color: #0b5ed7;
    border-color: #0a58ca;
    color: white;
}

.btn-primary:active {
    background-color: #0a58ca;
    border-color: #0a3622;
}
</style>

<!-- JavaScript -->
<script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
<script src="/js/searchManager.js"></script>

<script>
(function() {
    // Crear gestor de búsqueda centralizado
    const searchManager = new SearchManager({
        endpoint: '/api/search/smart',
        debounceDelay: 300,
        minChars: 1,
        onSuccess: (productos) => {
            displayResults(productos);
        },
        onError: (message) => {
            console.error('Search error:', message);
            document.getElementById('searchResults').style.display = 'none';
            document.getElementById('noResults').style.display = 'block';
            document.getElementById('noResults').textContent = message || 'No se encontraron productos';
        },
        onLoading: (isLoading) => {
            // Opcional: mostrar indicador de carga
        }
    });

    const searchInput = document.getElementById('searchInput');
    const searchBtn = document.getElementById('searchBtn');
    const searchByBarcodeCheckbox = document.getElementById('searchByBarcode');
    const resultsContainer = document.getElementById('searchResults');
    const resultsContent = document.getElementById('resultsContent');
    const noResults = document.getElementById('noResults');
    const searchBox = document.querySelector('.search-box-large');

    // Input en tiempo real (con debounce)
    searchInput.addEventListener('input', function() {
        searchManager.search(this.value);
    });

    // Botón de búsqueda (inmediato)
    searchBtn.addEventListener('click', function() {
        const value = searchInput.value.trim();
        if (value.length > 0) {
            searchBox.classList.add('active');
            setTimeout(() => searchBox.classList.remove('active'), 2000);
            searchManager.searchNow(value);
        }
    });

    // Tecla Enter - MOSTRAR COLOR VIOLETA
    searchInput.addEventListener('keypress', function(e) {
        if (e.key === 'Enter') {
            e.preventDefault();
            // Agregar clase activa (violeta)
            searchBox.classList.add('active');
            // Remover después de 2 segundos
            setTimeout(() => searchBox.classList.remove('active'), 2000);
            // Realizar búsqueda
            searchManager.searchNow(this.value);
        }
    });

    // Toggle barcode mode
    searchByBarcodeCheckbox.addEventListener('change', function() {
        if (searchInput.value.trim().length > 0) {
            searchBox.classList.add('active');
            setTimeout(() => searchBox.classList.remove('active'), 2000);
            searchManager.searchNow(searchInput.value);
        }
    });

    function displayResults(productos) {
        resultsContent.innerHTML = '';

        if (!productos || productos.length === 0) {
            resultsContainer.style.display = 'none';
            noResults.style.display = 'block';
            return;
        }

        productos.forEach(producto => {
            const card = document.createElement('div');
            card.className = 'product-card';
            card.innerHTML = `
                <div class="product-name">${producto.nombre || 'Sin nombre'}</div>
                <div class="product-details">
                    <div>Marca: ${producto.marca || 'N/A'}</div>
                    <div>Código: ${producto.codigo || 'N/A'}</div>
                    <div>Stock: ${producto.cantidad || 0}</div>
                    <div>Precio: $${(producto.precioMinorista || producto.valor || 0).toFixed(2)}</div>
                </div>
            `;
            
            card.addEventListener('click', () => {
                window.location.href = `/administrador/stock/producto/${producto._id}`;
            });

            resultsContent.appendChild(card);
        });

        resultsContainer.style.display = 'block';
        noResults.style.display = 'none';
    }

    // Auto-focus on load
    window.addEventListener('load', () => {
        searchInput.focus();
    });
})();
</script>
